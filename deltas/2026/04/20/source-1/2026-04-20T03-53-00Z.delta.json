    {
      "op": "replace",
      "at_from": 59,
      "at_to": 59,
      "from_paragraphs": [
        {
          "content_hash": "54951933dda90d80",
          "style": "NORMAL_TEXT",
          "text": "实际实力很一般（这个确实du），组内发paper多是因为Rice有个大佬帮带了她第一届学生"
        },
        {
          "content_hash": "262d2690348661fa",
